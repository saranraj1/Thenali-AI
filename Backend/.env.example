# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Data Paths
DATA_BASE_PATH=./data
REPO_BASE_PATH=./data/repos
FAISS_INDEX_PATH=./data/faiss_indexes

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE_MINUTES=1440

# RAG Pipeline
RAG_PIPELINE_PATH=./data/rag

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Application
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# S3 Bucket Names
S3_VOICE_BUCKET=bharat-ai-voice-recordings
S3_REPO_BUCKET=bharat-ai-repositories
S3_AVATAR_BUCKET=bharat-ai-profile-pictures
S3_BUCKET_NAME=bharat-ai-profile-pictures

# DynamoDB Table Names
DYNAMODB_USERS_TABLE=bharat_ai_users
DYNAMODB_REPOS_TABLE=bharat_ai_repositories
DYNAMODB_REPO_INTELLIGENCE_TABLE=bharat_ai_repo_intelligence
DYNAMODB_ROADMAPS_TABLE=bharat_ai_roadmaps
DYNAMODB_ASSESSMENTS_TABLE=bharat_ai_assessments
DYNAMODB_ACTIVITY_LOGS_TABLE=bharat_ai_activity_logs
DYNAMODB_PLAYGROUND_SESSIONS_TABLE=bharat_ai_playground_sessions
DYNAMODB_CHAT_MEMORY_TABLE=bharat_ai_chat_memory

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=ap-south-1

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Code Execution Sandbox
SANDBOX_TIMEOUT=10
SANDBOX_MAX_MEMORY_MB=128
